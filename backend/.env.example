# NeonBoost Panel Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Render keep-alive (Render sets this automatically — no need to add it manually)
# RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# MongoDB (Optional - currently using in-memory storage)
# MONGODB_URI=mongodb://localhost:27017/neonboost

# Telegram Bot Configuration
# Get these from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: separate Telegram chat just for free trial notifications
# If not set, free trial notifications go to TELEGRAM_CHAT_ID
# TELEGRAM_FREE_TRIAL_CHAT_ID=your_free_trial_chat_id_here

# Optional: separate Telegram chat for orders made with DISCORD5 promo code
# If not set, DISCORD5 orders go to TELEGRAM_CHAT_ID
# TELEGRAM_DISCORD5_CHAT_ID=your_discord5_chat_id_here

# Discord Webhook (for order notifications)
# Get your webhook URL from Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url/here

# CryptoMus Payment Integration
# Get these from your CryptoMus merchant dashboard: https://cryptomus.com
CRYPTOMUS_MERCHANT_ID=your_merchant_uuid_here
CRYPTOMUS_API_KEY=your_payment_api_key_here

# Your frontend URL (used for CryptoMus redirect after payment)
FRONTEND_URL=https://your-frontend-domain.com

# Your backend public URL (used for CryptoMus webhook callback)
APP_URL=https://your-backend.onrender.com

# Payment Configuration
# Bank of Georgia (BOG)
BANK_BOG_ACCOUNT=GE15BG0000000900450000

# TBC Bank
TBC_BANK_ACCOUNT=GE29TB0110000060701234

TELEGRAM_DISCORD5_CHAT_ID=-5166625502
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=neonboost2024